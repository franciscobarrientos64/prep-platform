{
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/casa-italia.html"
    },
    {
      "source": "/casa-italia",
      "destination": "/casa-italia.html"
    },
    {
      "source": "/hub",
      "destination": "/hub.html"
    },
    {
      "source": "/pos",
      "destination": "/pos-v2.html"
    },
    {
      "source": "/pos-v2",
      "destination": "/pos-v2.html"
    },
    {
      "source": "/pos2",
      "destination": "/pos/index.html"
    },
    {
      "source": "/pos-legacy",
      "destination": "/pos-legacy.html"
    },
    {
      "source": "/bienvenida",
      "destination": "/bienvenida.html"
    },
    {
      "source": "/reservar",
      "destination": "/bienvenida.html"
    },
    {
      "source": "/boh-compras",
      "destination": "/boh-compras.html"
    },
    {
      "source": "/boh-journey",
      "destination": "/boh-journey.html"
    },
    {
      "source": "/reservas-spec",
      "destination": "/reservas-spec.html"
    },
    {
      "source": "/reservas-widget",
      "destination": "/reservas-widget.html"
    },
    {
      "source": "/sistema",
      "destination": "/sistema.html"
    },
    {
      "source": "/prd",
      "destination": "/prd.html"
    },
    {
      "source": "/analisis",
      "destination": "/analisis.html"
    },
    {
      "source": "/roadmap",
      "destination": "/roadmap.html"
    },
    {
      "source": "/caja-chica",
      "destination": "/caja-chica.html"
    },
    {
      "source": "/inventario",
      "destination": "/inventario.html"
    },
    {
      "source": "/nav",
      "destination": "/nav.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "geolocation=(), microphone=(), camera=()" }
      ]
    },
    {
      "source": "/pos/env.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" },
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" }
      ]
    },
    {
      "source": "/pos/js/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/javascript; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/pos/css/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "text/css; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=300" }
      ]
    }
  ]
}
